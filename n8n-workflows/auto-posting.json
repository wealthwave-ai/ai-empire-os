        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/YOUR_IG_USER_ID/media_publish",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"creation_id\": \"{{ $json.id }}\",\n  \"access_token\": \"YOUR_META_PAGE_ACCESS_TOKEN\"\n}",
        "options": {}
      },
      "id": "a3000001-0000-0000-0000-000000000005",
      "name": "Instagram - Publish Post",

            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"model\": \"claude-opus-4-7\",\n  \"max_tokens\": 512,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Aaj ka Chaldean Numerology tip Hindi mein likho. 150 words se zyada nahi. Inspiring aur practical hona chahiye. Instagram post ke liye suitable hona chahiye. Emojis use karo. Sirf post content likho, koi explanation nahi.\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "a3000001-0000-0000-0000-000000000002",
      "name": "Claude - Generate Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const response = $input.first().json;\nconst postText = response.content[0].text;\nconst today = new Date().toLocaleDateString('hi-IN', { day: 'numeric', month: 'long', year: 'numeric' });\nconst caption = `${postText}\\n\\n📞 Apna numerology report order karein: https://ai-empire-os-two.vercel.app\\n\\n#Numerology #ChaldeanNumerology #Astrology #Hindi #Jyotish #NumerologyTips`;\nreturn [{ json: { post_text: postText, caption: caption, date: today } }];"
      },
      "id": "a3000001-0000-0000-0000-000000000003",
      "name": "Parse Claude Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/YOUR_IG_USER_ID/media",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"image_url\": \"https://YOUR_STATIC_IMAGE_URL\",\n  \"caption\": {{ JSON.stringify($json.caption) }},\n  \"access_token\": \"YOUR_META_PAGE_ACCESS_TOKEN\"\n}",
        "options": {}
      },
      "id": "a3000001-0000-0000-0000-000000000004",

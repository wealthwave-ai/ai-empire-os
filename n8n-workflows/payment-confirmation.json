        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_WATI_API_TOKEN"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messageText\": \"Shukriya {{ $('Webhook - Razorpay').item.json.body.payload.payment.entity.notes.customer_name }} ji! Aapka payment mil gaya. Aapka personal numerology report 24 ghante mein WhatsApp par aayega. 🙏\"\n}",
        "options": {}
      },
      "id": "a2000001-0000-0000-0000-000000000003",
      "name": "Send WhatsApp - Confirmation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [760, 220]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "=Skipped - event was: {{ $('Webhook - Razorpay').item.json.body.event }}"
            }
          ]
        },
        "options": {}
      },
      "id": "a2000001-0000-0000-0000-000000000004",
      "name": "Skip - Not Captured",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [760, 420]
    }
  ],
